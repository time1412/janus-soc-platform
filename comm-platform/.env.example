# ============================================================
#  내부 소통플랫폼 환경설정 (.env)
#  · 모바일 푸시 = 텔레그램 봇(버튼 강제 없음, HTML 서식). 역할별 chat_id로 전송.
#  · 메일 = SMTP. 수신 이메일은 '가입 시 등록한 이메일(동의자)'에서 자동 선택.
#  · 값이 비면 해당 채널은 드라이런(실제 발송 X, 처리이력만).
#  · 수정 후 8810 백엔드 재시작 필요.
# ============================================================

# ───────── 서버 ─────────
COMM_APP_HOST=0.0.0.0
COMM_APP_PORT=8810
COMM_BASE_URL=http://localhost:8810

# 단계 알림 전체 스위치 (false면 텔레그램·메일 모두 끔)
NOTIFY_ENABLED=true
# 폭주 가드: 팀별 60초당 실제 발송 상한(초과분은 '요약 1건'으로 대체). DDoS/스캔 시 서버 보호.
NOTIFY_RATE_MAX=10


# ============================================================
#  [사용] 텔레그램 봇 — 단계별 모바일 푸시 (카톡 대체)
#  발급법:
#   1) 텔레그램에서 @BotFather 검색 → /newbot → 봇 이름 지정 → 'Bot Token' 발급
#   2) 각 담당자가 그 봇과 1:1 대화 시작(아무 메시지/​/start) 또는 그룹에 봇 추가
#   3) chat_id 확인: 텔레그램에서 @userinfobot 에게 말 걸면 본인 chat_id 표시
#      (그룹이면 그룹 chat_id, 보통 마이너스로 시작)
#   4) 역할별 chat_id 입력. 테스트는 3개 모두 본인 chat_id로 넣으면 됨.
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_SOC=8649152859
TELEGRAM_CHAT_WEBADMIN=8649152859
TELEGRAM_CHAT_INFOSEC=8122659160


# ============================================================
#  [사용] 메일(SMTP) — 단계별 기록용 HTML 메일
#  · 수신자는 가입 이메일(동의자)에서 자동 선택. SMTP 서버 정보만 채우면 됨.
#  · 예) Gmail: smtp.gmail.com / 587 / 계정+앱비밀번호(2단계인증 후 발급)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=soc-noreply@company.local
SMTP_TLS=true


# ============================================================
#  [사용] 메일 게이트웨이 (janus.com 사용자별 사서함 webmail)
#  · 가입 시 <username>@janus.com 사서함 부여, 메일 비번=로그인 비번
#  · 백엔드가 그 자격으로 IMAP 수신 / SMTP 발송 대행
#  · ESXi 이전 시 MAIL_GATEWAY_HOST / MAIL_SSH_HOST만 10.0.10.50으로 교체
# ============================================================
MAIL_GATEWAY_HOST=192.168.126.222
MAIL_DOMAIN=janus.com
MAIL_IMAP_PORT=993
MAIL_SMTP_PORT=25
MAIL_SMTP_STARTTLS=true
MAIL_TLS_VERIFY=false
# 가입 시 사서함 자동 생성(랩: 게이트웨이 sudo로 virtual_users INSERT)
MAIL_PROVISION_ENABLED=true
MAIL_SSH_HOST=192.168.126.222
MAIL_SSH_PORT=22
MAIL_SSH_USER=mailadmin
MAIL_SSH_PASSWORD=


# ============================================================
#  (미사용) 카톡 — 텔레그램으로 전환. 되돌릴 때만 주석 해제.
#  (TELEGRAM_BOT_TOKEN이 설정되면 카톡은 무시되고 텔레그램이 사용됨)
# ============================================================
# KAKAO_REST_KEY=
# KAKAO_CLIENT_SECRET=
# KAKAO_REFRESH_SOC=
# KAKAO_REFRESH_WEBADMIN=
# KAKAO_REFRESH_INFOSEC=

# ── (미사용) 역할별 고정 수신 이메일 / AI 연동 ──
# NOTIFY_EMAIL_SOC=
# NOTIFY_EMAIL_WEBADMIN=
# NOTIFY_EMAIL_INFOSEC=
# GEMINI_API_KEY=
