# --- Splunk (Tailscale 경유 REST 접속) ---
SPLUNK_HOST=192.168.126.201
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=
# 토큰 인증 시 (있으면 우선 사용)
SPLUNK_TOKEN=
SPLUNK_VERIFY_SSL=false

# --- Gemini AI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Threat Intelligence ---
ABUSEIPDB_API_KEY=
OTX_API_KEY=
TI_CACHE_TTL_HOURS=24

# --- 데모/목 모드 (true면 실제 Splunk/Gemini 없이 샘플 데이터로 동작) ---
SOC_MOCK=false

# --- 서버 ---
# 포트 8000은 Splunk Web이 사용하므로 8800 사용
APP_HOST=10.0.200.222
APP_PORT=8800
